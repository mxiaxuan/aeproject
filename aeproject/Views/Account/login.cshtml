@{
    Layout = null; // 不使用佈局
}

<!-- login.cshtml -->
@{
    ViewData["Title"] = "登入";
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>@ViewData["Title"]</title>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .login-container {
            max-width: 400px;
            margin: auto;
            padding: 20px;
            background-color: white;
            border: 2px solid #000000;
            border-radius: 5px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        .custom-btn {
            background-color: #131728;
            color: white;
            border: none;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

            .custom-btn:hover {
                background-color: #ffffff;
                color: #131728;
            }

        .forgot-password, .register-link {
            color: #81b1c5;
            text-decoration: none;
            transition: color 0.2s;
        }

            .forgot-password:hover, .register-link:hover {
                color: #16360a;
                text-decoration: none;
            }

        .form-control:focus {
            border-color: #666f78;
            box-shadow: 0 0 5px rgba(129, 177, 197, 0.5);
            outline: none;
        }

        /* 註冊文字樣式 */
        .register-text {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #666;
        }

        /* 點擊註冊的樣式 */
        .register-link {
            margin-left: 5px;
            color: #81b1c5;
            text-decoration: none;
            padding: 0;
        }

            .register-link:hover {
                color: #16360a;
            }

        /* 錯誤樣式 */
        .error-message {
            color: #dc3545;
            font-size: 0.8rem;
            margin-top: 0.25rem;
            display: none;
        }

        /* 社交按鈕樣式 */
        .social-btn {
            margin-top: 10px;
            display: flex;
            justify-content: space-around;
        }

            .social-btn a {
                text-align: center;
                padding: 10px;
                border-radius: 50%;
                background-color: #000912;
                color: white;
                transition: background-color 0.3s;
                width: 50px; /* 按鈕寬度 */
                height: 50px; /* 按鈕高度 */
                display: flex;
                align-items: center;
                justify-content: center;
            }

                .social-btn a:hover {
                    background-color: #FFF;
                    border: 1px solid #000000;
                }
    </style>
</head>
<body>
    <div class="login-container mt-5">
        <h5 class="text-center">@ViewData["Title"]</h5>
        <form id="loginForm" method="post" asp-controller="Account" asp-action="Login" class="mt-4" novalidate>
            <div class="form-group">
                <label for="username">帳號:</label>
                <input type="text" id="username" name="username" class="form-control" required>
                <div class="error-message">請填寫這個欄位</div>
            </div>
            <div class="form-group">
                <label for="password">密碼:</label>
                <input type="password" id="password" name="password" class="form-control" required>
                <div class="error-message">請填寫這個欄位</div>
            </div>
            <div class="d-flex justify-content-between form-check">
                <div>
                    <input type="checkbox" id="rememberMe" name="rememberMe" class="form-check-input">
                    <label for="rememberMe" class="form-check-label">記住密碼</label>
                </div>
                <div>
                    <a href="/Account/ForgotPassword" class="forgot-password">忘記密碼？</a>
                </div>
            </div>
            <button type="submit" class="btn custom-btn btn-block mt-3">登入</button>
            <!-- 註冊選項 -->
            <div class="register-text">
                <span>還沒有帳號嗎?</span>
                <a href="/Account/Register" class="register-link">點擊註冊</a>
            </div>
            <!-- 社交登入按鈕 -->
            <div class="social-btn mt-4">
                <a href="/Account/LoginWithFacebook" class="btn btn-facebook">
                    <i class="fab fa-facebook-f"></i>
                </a>
                <a href="/Account/LoginWithGoogle" class="btn btn-google">
                    <i class="fab fa-google"></i>
                </a>
                <a href="/Account/LoginWithLine" class="btn btn-line">
                    <i class="fab fa-line"></i>
                </a>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // 驗證表單輸入
        document.getElementById("loginForm").addEventListener("submit", function (event) {
            var isValid = true;
            var inputs = document.querySelectorAll("#loginForm .form-control");

            inputs.forEach(function (input) {
                var errorMessage = input.nextElementSibling;
                if (!input.value.trim()) {
                    isValid = false;
                    errorMessage.style.display = "block";
                    input.classList.add("is-invalid");
                } else {
                    errorMessage.style.display = "none";
                    input.classList.remove("is-invalid");
                }

                // 隱藏錯誤訊息當欄位取得焦點
                input.addEventListener("focus", function () {
                    errorMessage.style.display = "none";
                    input.classList.remove("is-invalid");
                });
            });

            if (!isValid) {
                event.preventDefault();
            }
        });
    </script>
</body>
</html>
