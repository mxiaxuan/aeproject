@{
    Layout = null; // 不使用佈局
}

<!-- login.cshtml -->
@{
    ViewData["Title"] = "登入";
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <title>@ViewData["Title"]</title>
    <style>
        body {
            background-color: #f8f9fa;
        }

        .login-container {
            max-width: 400px;
            margin: auto;
            padding: 20px;
            background-color: white;
            border: 2px solid #000000;
            border-radius: 5px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        .custom-btn {
            background-color: #131728;
            color: white;
            border: none;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        .custom-btn:hover {
            background-color: #ffffff;
            color: #131728;
            border: 1px solid #000000;
        }

        .forgot-password, .register-link {
            color: #81b1c5;
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-password:hover, .register-link:hover {
            color: #16360a;
            text-decoration: none;
        }

        .form-control:focus {
            border-color: #666f78;
            box-shadow: 0 0 5px rgba(129, 177, 197, 0.5);
            outline: none;
        }

        .register-text {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #666;
        }

        .register-link {
            margin-left: 5px;
            color: #81b1c5;
            text-decoration: none;
            padding: 0;
        }

        .register-link:hover {
            color: #16360a;
        }

        .error-message {
            color: #dc3545;
            font-size: 0.8rem;
            margin-top: 0.25rem;
            display: none;
        }

        .login-error {
            color: #dc3545;
            font-size: 1rem;
            text-align: center;
            margin-bottom: 15px;
        }

        .social-btn {
            margin-top: 10px;
            display: flex;
            justify-content: space-around;
        }

        .social-btn a {
            text-align: center;
            padding: 10px;
            border-radius: 50%;
            background-color: #000912;
            color: white;
            transition: background-color 0.3s;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .social-btn a:hover {
            background-color: #FFF;
            border: 1px solid #000000;
        }

        .custom-alert {
            max-width: 300px; /* 自訂最大寬度 */
            max-height: 50px; /* 自訂最大高度 */
            font-size: 0.9rem; /* 自訂字體大小 */
            margin: 0 auto; /* 使警報在中心顯示 */
        }
    </style>
</head>
<body>
    <div class="login-container mt-5">
        <h5 class="text-center">@ViewData["Title"]</h5>

        <form id="loginForm" method="post" asp-controller="Account" asp-action="Login" class="mt-4" novalidate>
            @if (ViewBag.LoginFailed != null)
            {
                <div class="alert alert-danger alert-dismissible fade show custom-alert mb-3" role="alert">
                    @ViewBag.LoginFailed
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            }
            <div class="form-group">
                <label for="username">帳號:</label>
                <input type="text" id="username" name="username" class="form-control" required>
                <div class="error-message">請填寫這個欄位</div>
            </div>
            <div class="form-group">
                <label for="password">密碼:</label>
                <input type="password" id="password" name="password" class="form-control" required>
                <div class="error-message">請填寫這個欄位</div>
            </div>
            <button type="submit" class="btn custom-btn btn-block mt-5">登入</button>
            <div class="register-text mb-3">
                <span>還沒有帳號嗎?</span>
                <a href="/Account/Register" class="register-link">點擊註冊</a>
            </div>
            <div class="social-btn mt-6">
                <a href="/Account/LoginWithGoogle" class="btn btn-google" title="使用 Google 登入">
                    <i class="fab fa-google"></i>
                </a>
                <a href="/Account/LoginWithLine" class="btn btn-line" title="使用 LINE 登入">
                    <i class="fab fa-line"></i>
                </a>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
        document.getElementById("loginForm").addEventListener("submit", function (event) {
            var isValid = true;
            var inputs = document.querySelectorAll("#loginForm .form-control");

            inputs.forEach(function (input) {
                var errorMessage = input.nextElementSibling;
                if (!input.value.trim()) {
                    isValid = false;
                    errorMessage.style.display = "block";
                    input.classList.add("is-invalid");
                } else {
                    errorMessage.style.display = "none";
                    input.classList.remove("is-invalid");
                }

                input.addEventListener("focus", function () {
                    errorMessage.style.display = "none";
                    input.classList.remove("is-invalid");
                });
            });

            if (!isValid) {
                event.preventDefault();
            }
        });
    </script>
</body>
</html>