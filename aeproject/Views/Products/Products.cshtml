@{
    Layout = null; // 不使用佈局
}

@model IEnumerable<aeproject.Models.Product>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>ae shop - Product</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto+Slab:400,100,300,700" rel="stylesheet" type="text/css" />
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="//maxcdn.bootstrapcdn.com/font-awesome/4.2.0/css/font-awesome.min.css" rel="stylesheet">

    <style>
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1020;
            padding-top: 3px;
            padding-bottom: 3px;
        }

        .home-button {
            z-index: 9999;
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #1e29347a;
            color: white;
            width: 50px;
            height: 50px;
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }

            .home-button.visible {
                opacity: 1;
                pointer-events: auto;
            }

            .home-button:hover {
                background-color: #000912;
                color: white;
            }

        * {
            box-sizing: border-box;
        }

        body {
            background: #222;
            margin: 2em 20em;
            box-sizing: border-box;
        }

        .searchform {
            display: block;
            margin: 0;
            overflow: hidden;
            width: 70%;
        }

        label, input {
            vertical-align: baseline;
            color: #737373;
        }

        label {
            margin: 0.075em 0.2em 0 0;
            float: right;
        }

        input[type="search"] {
            border: 2px solid #737373;
            border-width: 0 0 3px;
            background-color: transparent;
            font: 15px "Open Sans", sans-serif;
            padding: 0.075em 0.2em;
            width: 100%;
            float: left;
        }

            input[type="search"]::-webkit-search-cancel-button {
                display: none;
            }

            input[type="search"]:focus {
                color: #FFF;
                border-color: #FFF;
                outline: none;
            }

        body {
            background: linear-gradient(to bottom, #f0f8ff, #000000cc);
            background-attachment: fixed;
            background-size: cover;
            color: #333;
            margin: 0;
            padding: 0;
        }

        .carousel,
        .carousel-inner,
        .carousel-item {
            width: 100%;
            height: 60vh;
        }

        .carousel-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .carousel-indicators {
            margin-top: -30px;
        }

            .carousel-indicators button {
                background-color: rgba(255, 255, 255, 0.5);
                border: none;
                width: 50px;
                height: 5px;
                border-radius: 0%;
                transition: background-color 0.3s ease, transform 0.1s ease;
                margin-right: 10px;
            }

            .carousel-indicators .active {
                background-color: rgba(255, 255, 255, 0.75);
            }

            .carousel-indicators button:active {
                background-color: rgba(255, 255, 255, 1);
                transform: scale(1.2);
            }

        .card-title {
            font-size: 0.9rem;
        }

        /* 調整卡片容器樣式，背景變黑色，並移除邊框 */
        .product-card .card {
            background-color: black; /* 設定背景為黑色 */
            border: none; /* 移除邊框 */
            width: 250px;
            height: 380px; /* 調整卡片高度 */
            margin-bottom: 20px;
            overflow: hidden;
            text-decoration: none;
            color: white; /* 文字顏色為白色 */
        }

            .product-card .card:hover {
                transform: scale(1.05);
                box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.3);
            }

        .product-card .card-img-top {
            height: 300px; /* 設定固定高度 */
            width: 100%;
            object-fit: cover; /* 讓圖片填滿容器，並裁切多餘部分 */
        }

        /* 調整卡片內文部分，讓文字靠左對齊 */
        .product-card .card-body {
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: left; /* 文字靠左對齊 */
            padding: 15px;
        }

        /* 調整標題和價格的字型大小 */
        .product-card .card-title {
            font-size: 0.7rem; /* 調小字體 */
            margin-bottom: 5px;
            white-space: nowrap; /* 不換行 */
            overflow: hidden; /* 超出部分隱藏 */
            text-overflow: ellipsis; /* 超出部分顯示省略號 */
        }

        .product-card .card-text {
            font-size: 0.75rem; /* 調小字體 */
            color: #ccc; /* 更淡的顏色 */
        }

        /* 調整卡片在 hover 時的效果 */
        .product-card .card:hover {
            transform: scale(1.05);
            box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.3);
        }
    </style>
</head>
<body id="page-top">
    <a href="@Url.Action("Index", "Products")" class="home-button" id="backToHome">
        <i class="fa-sharp fa-light fa-house"></i>
    </a>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <!-- 左側內容 -->
            <div class="navbar-left d-flex align-items-center">
                <a class="navbar-brand" href="/">
                    <img src="~/assets/img/aespalogo.png" alt="Logo" style="max-width: 80px; height: auto;" />
                </a>

                <ul class="navbar-nav">
                    <!-- 商品分類下拉選單 -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            商品分類
                        </a>
                        <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                            <a class="dropdown-item album-filter" data-album="all" href="#">全部</a>
                            <a class="dropdown-item album-filter" data-album="8" href="#">迷你專輯 / MY WORLD</a>
                            <a class="dropdown-item album-filter" data-album="9" href="#">迷你專輯 / Drama</a>
                            <a class="dropdown-item album-filter" data-album="11" href="#">正規專輯 / Armageddon</a>
                            <a class="dropdown-item album-filter" data-album="13" href="#">迷你專輯 / Whiplash</a>
                            <a class="dropdown-item album-filter" data-album="23" href="#">2024 aespa LIVE TOUR - SYNK : PARALLEL LINE</a>
                        </div>
                    </li>
                </ul>
            </div>

            <!-- 右側內容 -->
            <div class="navbar-right d-flex align-items-center ml-auto">
                <form class="searchform group mr-3">
                    <input type="search" id="search-box" placeholder="Search">
                </form>
                <ul class="navbar-nav align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-user"></i> @User.Identity.Name
                            </a>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                    <button type="submit" class="dropdown-item">登出</button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">登入</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <header class="masthead">
        <div id="carouselExampleIndicators" class="carousel slide" data-ride="carousel" data-interval="3000">
            <div class="carousel-indicators">
                <button type="button" data-target="#carouselExampleIndicators" data-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-target="#carouselExampleIndicators" data-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-target="#carouselExampleIndicators" data-slide-to="2" aria-label="Slide 3"></button>
                <button type="button" data-target="#carouselExampleIndicators" data-slide-to="3" aria-label="Slide 4"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="assets/img/slider1.jpg" class="d-block w-100 carousel-img" alt="Slider Image 1">
                </div>
                <div class="carousel-item">
                    <img src="assets/img/slider4.jpg" class="d-block w-100 carousel-img" alt="Slider Image 4">
                </div>
                <div class="carousel-item">
                    <img src="assets/img/slider3.jpg" class="d-block w-100 carousel-img" alt="Slider Image 3">
                </div>
                <div class="carousel-item">
                    <img src="assets/img/slider2.jpg" class="d-block w-100 carousel-img" alt="Slider Image 2">
                </div>
            </div>
            <a class="carousel-control-prev" href="#carouselExampleIndicators" role="button" data-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="sr-only">Previous</span>
            </a>
            <a class="carousel-control-next" href="#carouselExampleIndicators" role="button" data-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="sr-only">Next</span>
            </a>
        </div>
    </header>

    <div class="container">
        <div class="container mt-4">
            <div class="row justify-content-start">
                @foreach (var product in Model)
                {
                    <div class="col-md-3 mt-3 product-card" data-product-name="@product.ProductName.ToLower()" data-album-id="@product.AlbumId">
                        <a href="@Url.Action("Details", "Products", new { id = product.ProductId })" class="card">
                            <img src="@Url.Content(product.ProductImage)" class="card-img-top ps-3" alt="@product.ProductName">
                            <div class="card-body">
                                <h5 class="card-title">@Html.DisplayFor(modelItem => product.ProductName)</h5>
                                <p class="card-text">NT $@product.Price.ToString("N0")</p>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const backButton = document.getElementById("backToHome");
            const searchBox = document.getElementById("search-box");
            const productCards = document.querySelectorAll(".product-card");
            const albumFilterLinks = document.querySelectorAll(".album-filter");

            // 顯示返回首頁按鈕
            window.addEventListener("scroll", function () {
                if (window.scrollY > 200) {
                    backButton.classList.add("visible");
                } else {
                    backButton.classList.remove("visible");
                }
            });

            // 搜尋功能
            searchBox.addEventListener("input", function (event) {
                const query = event.target.value.toLowerCase();
                productCards.forEach(function (card) {
                    const productName = card.querySelector(".card-title").textContent.toLowerCase();
                    if (productName.includes(query)) {
                        card.style.display = "block";
                    } else {
                        card.style.display = "none";
                    }
                });
            });

            // 分類篩選功能
            albumFilterLinks.forEach(function (link) {
                link.addEventListener("click", function (event) {
                    event.preventDefault();
                    const albumId = event.target.dataset.album;

                    $('.product-card').each(function () {
                        var productAlbumId = $(this).data('album-id');
                        // 顯示所有產品，或僅顯示符合 albumId 的產品
                        if (albumId === 'all' || productAlbumId == albumId) {
                            $(this).show();
                        } else {
                            $(this).hide();
                        }
                    });
                });
            });
        });
    </script>
</body>
</html>
