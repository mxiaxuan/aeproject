@{
    Layout = null; // 不使用佈局
}

@model aeproject.Models.Product

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>ae shop - Product</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto+Slab:400,100,300,700" rel="stylesheet" type="text/css" />
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
</head>
<body id="page-top">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <div class="navbar-left d-flex align-items-center">
                <a class="navbar-brand" href="#page-top">
                    <img src="~/assets/img/aespalogo.png" alt="Logo" style="max-width: 80px; height: auto;" />
                </a>
            </div>
            <div class="navbar-right d-flex align-items-center ml-auto">
                <ul class="navbar-nav align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-user"></i> @User.Identity.Name
                            </a>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                    <button type="submit" class="dropdown-item">登出</button>
                                    <a class="dropdown-item" asp-controller="Favorites" asp-action="Favorites">我的收藏</a> <!-- 收藏頁面連結 -->
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">登入</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- 商品詳細頁 -->
    <div class="product-details-container d-flex align-items-start">
        <!-- 左側圖片 -->
        <div class="product-image">
            <img src="@Model.ProductImage" alt="@Model.ProductName" class="img-fluid" />
        </div>

        <!-- 右側內容 -->
        <div class="product-info">
            <h2 class="product-title">@Model.ProductName</h2>
            <div class="d-flex justify-content-between align-items-center">
                <p class="product-price text-danger">
                    NT$@String.Format("{0:N0}", Model.Price)
                </p>
                <a href="javascript:void(0);" onclick="addToFavorites()" class="ml-2" style="float: right;">
                    <i class="fas fa-heart" id="favoriteIcon" style="color: #FFF;"></i>
                </a>
            </div>

            <hr class="divider" />

            <!-- 手風琴效果 -->
            <div class="accordion" id="productAccordion">
                <div class="card">
                    <div class="card-header" id="headingOne">
                        <button class="accordion-button" type="button" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne" onclick="toggleIcon(this)">
                            Product Detail
                            <i class="fas fa-chevron-down accordion-icon"></i>
                        </button>
                    </div>

                    <div id="collapseOne" class="collapse mt-0" aria-labelledby="headingOne" data-parent="#productAccordion">
                        <div class="card-body">
                            @Model.Description
                        </div>
                    </div>
                </div>
            </div>
            <hr class="divider" />
            <div class="quantity-selector mt-3">
                <label for="quantity">數量：</label>
                <div class="quantity-control">
                    <button type="button" class="btn btn-outline-secondary" onclick="decreaseQuantity()">-</button>
                    <input id="quantityDisplay" type="text" class="quantity-display" value="1" oninput="manualQuantityChange()" />
                    <button type="button" class="btn btn-outline-secondary" onclick="increaseQuantity()">+</button>
                </div>
            </div>

            <p class="product-stock">庫存數量: @Model.StockQuantity</p>

            <div class="d-flex justify-content-between mt-4">
                <button class="btn btn-custom btn-add-to-cart"><i class="fa-thin fa-cart-circle-plus"></i>加入購物車</button>
                <button class="btn btn-custom btn-buy-now">購買</button>
            </div>
        </div>
    </div>

    @* 推薦商品 *@
    @{
        var recommendedProducts = ViewData["RecommendedProducts"] as List<aeproject.Models.Product>;
    }
    <div class="recommended">
        <!-- 推薦商品展示邏輯 -->
    </div>

    <script>
        function toggleIcon(element) {
            const icon = element.querySelector('.accordion-icon');
            if (icon.classList.contains('fa-chevron-down')) {
                icon.classList.remove('fa-chevron-down');
                icon.classList.add('fa-chevron-up');
            } else {
                icon.classList.remove('fa-chevron-up');
                icon.classList.add('fa-chevron-down');
            }
        }

        function increaseQuantity() {
            const quantityDisplay = document.getElementById('quantityDisplay');
            quantityDisplay.value = parseInt(quantityDisplay.value) + 1;
        }

        function decreaseQuantity() {
            const quantityDisplay = document.getElementById('quantityDisplay');
            if (parseInt(quantityDisplay.value) > 1) {
                quantityDisplay.value = parseInt(quantityDisplay.value) - 1;
            }
        }

        function manualQuantityChange() {
            const quantityDisplay = document.getElementById('quantityDisplay');
            if (parseInt(quantityDisplay.value) < 1) {
                quantityDisplay.value = 1;
            }
        }

        function addToFavorites() {
            const favoriteIcon = document.getElementById("favoriteIcon");
            if (favoriteIcon.style.color === "rgb(255, 0, 0)") {
                favoriteIcon.style.color = "#FFF";
            } else {
                favoriteIcon.style.color = "rgb(255, 0, 0)";
            }
        }
    </script>
</body>
</html>
