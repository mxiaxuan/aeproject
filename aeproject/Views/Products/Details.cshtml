@{
    Layout = null; // 不使用佈局
}

@model aeproject.Models.Product

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>ae shop - Product</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css?family=Roboto+Slab:400,100,300,700" rel="stylesheet" type="text/css" />
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

    <style>
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1020;
            padding-top: 3px;
            padding-bottom: 3px;
        }

        body {
            background: linear-gradient(to bottom, #f0f8ff, #000000cc);
            background-attachment: fixed;
            background-size: cover;
            color: #333;
            margin: 0;
            padding: 0;
        }

        .product-details-container {
            display: flex;
            align-items: flex-start;
            padding: 50px;
            background-color: #ffffff3d;
            color: black;
            border-radius: 8px;
            max-width: 800px;
            margin: 20px auto;
        }

        .product-image {
            flex: 0 0 40%;
            margin-right: 20px;
        }

            .product-image img {
                max-width: 100%;
                border-radius: 8px;
                object-fit: cover;
            }

        .product-info {
            flex: 1;
        }

        .product-title {
            font-size: 1.4rem;
            font-weight: bold;
            margin-bottom: 6px;
        }

        .product-price {
            font-size: 1.1rem;
            color: red;
            margin-bottom: 6px;
        }

        .divider {
            border-top: 1px solid #555;
            margin: 6px 0;
        }

        .product-stock {
            font-size: 0.85rem;
            color: black;
            margin-bottom: 12px;
        }

        .add-to-cart {
            font-size: 0.85rem;
            padding: 6px 12px;
        }

        /* 手風琴樣式 */
        .accordion .card-header {
            background-color: #343a40;
            color: white;
            padding: 0.5rem 1.25rem;
            border-radius: 5px;
        }

        .accordion-button {
            color: white;
            font-size: 0.8rem;
            text-align: left;
            width: 100%;
            padding: 0.1rem 1rem;
            background-color: transparent;
            border: none;
            display: flex;
            align-items: center;
            justify-content: start; /* 調整為左對齊 */
        }

            .accordion-button:hover {
                color: #FFF;
            }

            .accordion-button:focus {
                box-shadow: none;
            }

        /* 旋轉的三角形圖示 */
        .accordion-icon {
            transition: transform 0.3s ease;
            margin-left: auto; /* 讓圖示在右側 */
        }

            .accordion-icon.rotate {
                transform: rotate(180deg);
            }

        /* 手風琴內容樣式 */
        .accordion .card-body {
            font-size: 0.8rem;
            background-color: #f8f9fa;
            color: #333;
            padding: 0.5rem 1rem 1rem;
            white-space: pre-line;
        }

        .quantity-selector {
            display: flex;
            align-items: baseline;
            margin-bottom: 8px;
            font-size: 1rem;
        }

            .quantity-selector label {
                margin-right: 10px;
                font-weight: bold;
            }

            .quantity-selector input[type="number"] {
                width: 60px;
                text-align: center;
                border: 1px solid #ccc;
                border-radius: 4px;
                margin-right: 10px;
            }

        .btn-custom {
            background-color: #000;
            font-size: 0.9rem;
            padding: 8px 16px;
            border-radius: 5px;
            font-weight: bold;
        }

        .btn-add-to-cart {
            background-color: #000;
            color: white;
            margin-right: 10px;
        }

            .btn-add-to-cart:hover {
                background-color: #FFF;
            }

        .btn-buy-now {
            background-color: #000;
            color: white;
        }

            .btn-buy-now:hover {
                background-color: #FFF;
            }
    </style>
</head>
<body id="page-top">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <div class="navbar-left d-flex align-items-center">
                <a class="navbar-brand" href="#page-top">
                    <img src="~/assets/img/aespalogo.png" alt="Logo" style="max-width: 80px; height: auto;" />
                </a>
            </div>
            <div class="navbar-right d-flex align-items-center ml-auto">
                <ul class="navbar-nav align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-user"></i> @User.Identity.Name
                            </a>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                                    <button type="submit" class="dropdown-item">登出</button>
                                </form>
                            </div>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">登入</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- 商品詳細頁 -->
    <div class="product-details-container d-flex align-items-start">
        <!-- 左側圖片 -->
        <div class="product-image">
            <img src="@Model.ProductImage" alt="@Model.ProductName" class="img-fluid" />
        </div>

        <!-- 右側內容 -->
        <div class="product-info">
            <h2 class="product-title">@Model.ProductName</h2>
            <p class="product-price text-danger">NT$@String.Format("{0:N0}", Model.Price)</p>
            <hr class="divider" />

            <!-- 手風琴效果 -->
            <div class="accordion" id="productAccordion">
                <div class="card">
                    <div class="card-header" id="headingOne">
                        <button class="accordion-button" type="button" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne" onclick="toggleIcon(this)">
                            Product Detail
                            <i class="fas fa-chevron-down accordion-icon"></i>
                        </button>
                    </div>

                    <div id="collapseOne" class="collapse show mt-0" aria-labelledby="headingOne" data-parent="#productAccordion">
                        <div class="card-body">
                            @Model.Description
                        </div>
                    </div>
                </div>
            </div>
            <hr class="divider" />
            <div class="quantity-selector">
                <label for="quantity">數量：</label>
                <input type="number" id="quantity" name="quantity" value="1" min="1" max="@Model.StockQuantity" />
            </div>

            <p class="product-stock">庫存數量: @Model.StockQuantity</p>

            <!-- 修改後的按鈕樣式 -->
            <button class="btn btn-custom btn-add-to-cart">加入購物車</button>
            <button class="btn btn-custom btn-buy-now ms-3">購買</button>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.6/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script>
        function toggleIcon(button) {
            const icon = button.querySelector('.accordion-icon');
            icon.classList.toggle('rotate');
        }
    </script>
</body>
</html>
