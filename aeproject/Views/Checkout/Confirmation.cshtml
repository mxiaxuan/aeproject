@model Order

<h1>訂單確認</h1>
<p>訂單號碼: @Model.OrderId</p>
<p>訂單日期: @Model.OrderDate</p>
<p>配送地址: @Model.ShippingAddress</p>
<p>總金額: @Model.TotalAmount</p>
<h3>商品清單</h3>
<ul>
    @foreach (var item in Model.OrderItems)
    {
        <li>@item.ProductId - @item.Quantity x @item.Price = @item.TotalPrice</li>
    }
</ul>
