@model IEnumerable<aeproject.Models.Album>

@{
    ViewData["Title"] = "Index";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <h1>曲目一覽</h1>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.AlbumName)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ReleaseDate)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.AlbumType)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.AlbumCover)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Agency)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.AlbumName)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.ReleaseDate)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.AlbumType)
                            </td>
                            <td>
                                <!-- 使用 AlbumCover 作為圖片的 src -->
                                <img src="@Url.Content(item.AlbumCover)" alt="Album Cover" style="max-width: 100px; max-height: 100px;" />
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Agency)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            fetch('@Url.Action("AlbumListPartial", "Albums")')
                .then(response => response.text())
                .then(data => {
                    document.getElementById("album-section").innerHTML = data;
                })
                .catch(error => {
                    console.error('Error loading albums:', error);
                });
        });
    </script>
}
